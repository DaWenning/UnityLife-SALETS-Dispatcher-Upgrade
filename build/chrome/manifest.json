{
    "manifest_version":  3,
    "name":  "UnityLife SALETS Injector",
    "version":  "1.1.0",
    "description":  "Injects custom JS and CSS into a target website.",
    "permissions":  [

                    ],
    "content_scripts":  [
                            {
                                "matches":  [
                                                "https://authority.ulife.me/pd/dutyshow",
                                                "https://authority.ulife.me/pd/controlcenter",
                                                "https://trainingauthority.ulife.me/*"
                                            ],
                                "js":  [
                                           "content/inject.js"
                                       ],
                                "css":  [
                                            "content/inject.css"
                                        ],
                                "run_at":  "document_idle"
                            }
                        ],
    "icons":  {
                  "16":  "icons/icon16.png",
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              }
}