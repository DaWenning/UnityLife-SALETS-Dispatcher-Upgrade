{
  "manifest_version": 2,
  "name": "UnityLife SALETS Injector",
  "version": "1.0.0",
  "description": "Injects custom JS and CSS into a target website.",

  "browser_specific_settings": {
    "gecko": {
      "id": "salets-injector@unitylife",
      "strict_min_version": "57.0"
    }
  },

  "permissions": [
    "https://authority.ulife.me/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://authority.ulife.me/pd/dutyshow*", "https://authority.ulife.me/pd/controlcenter*", "https://trainingauthority.ulife.me/*"],
      "js": ["content/inject.js"],
      "css": ["content/inject.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "64":  "icons/icon64.png",
    "128": "icons/icon128.png"
  }
}
